rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Projects collection
    match /projects/{projectId} {
      // For now, allow all authenticated users to read/write for the demo
      // In a real app, we'd check roles (which we can do via a users collection or custom claims)
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      // Validation could be added here (Phase 4 of skill)
    }
    
    // Support other collections as needed
    match /access_requests/{requestId} {
      allow read, write: if isSignedIn();
    }
  }
}
