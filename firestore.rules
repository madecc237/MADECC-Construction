rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Projects collection
    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }
    
    match /contracts/{id} { allow read, write: if isSignedIn(); }
    match /payments/{id} { allow read, write: if isSignedIn(); }
    match /employees/{id} { allow read, write: if isSignedIn(); }
    match /invoices/{id} { allow read, write: if isSignedIn(); }
    match /system/{id} { allow read, write: if false; } // Locked by default
    
    // Support other collections as needed
    match /access_requests/{requestId} {
      allow read, write: if isSignedIn();
    }
  }
}
